# ATLAS environment template — copy to .env and fill in.
# Never commit real values.

# --- Supabase CLI (login via `supabase login` OR paste a personal
#     access token from https://supabase.com/dashboard/account/tokens)
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_REF=
SUPABASE_DB_PASSWORD=

# --- Supabase runtime (Project Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key is used ONLY by apps/api and apps/workers. Never in the browser.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- Web (browser-safe values only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- API
API_PORT=4000
JWT_AUDIENCE=authenticated

# --- Redis / BullMQ
REDIS_URL=redis://localhost:6379

# --- AI: Moonshot Kimi (https://platform.moonshot.ai)
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
MOONSHOT_MODEL=kimi-k2-0905-preview

# --- Observability
LOG_LEVEL=info
SENTRY_DSN=
