{
  "name": "@atlas/workers",
  "version": "0.1.0",
  "private": true,
  "description": "ATLAS background workers — BullMQ queues for reports, notifications, imports and billing",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "drain": "node dist/drain-outbox.js",
    "drain:once": "node dist/drain-outbox.js --once",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.47.0",
    "bullmq": "^5.34.0",
    "pino": "^9.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
